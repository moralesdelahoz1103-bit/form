# ==================================================
# CONFIGURACIÓN COSMOSDB
# ==================================================

# CosmosDB Endpoint (Account Endpoint)
COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
# CosmosDB Key (Account Key)
COSMOS_KEY=your_primary_or_secondary_key_here
# Nombre de la base de datos
COSMOS_DATABASE_NAME=formaciones_db

# Modo de almacenamiento: "json" o "cosmosdb"
# json = archivos locales 
# cosmosdb = Azure CosmosDB
STORAGE_MODE=json

# Modo de almacenamiento de blobs (QR, firmas): "local" o "azure"
# local = sistema de archivos local
# azure = Azure Blob Storage
BLOB_STORAGE_MODE=local

# Azure Blob Storage Connection String (solo si BLOB_STORAGE_MODE=azure)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=xxx;AccountKey=xxx;EndpointSuffix=core.windows.net

# ==================================================
# OTRAS CONFIGURACIONES
# ==================================================

# URL del frontend (se usará para generar links de registro y CORS)
# Local: http://localhost:3000 o http://localhost:5173
# Azure: https://your-app-web.azurecontainerapps.io (OBLIGATORIO HTTPS)
FRONTEND_URL=http://localhost:3000

# API Port (por defecto 8000)
API_PORT=8000

# Configuración de negocio
ALLOWED_DOMAIN=@fundacionsantodomingo.org
TOKEN_EXPIRY_DAYS=30
MAX_FILE_SIZE=1048576

# Entra ID (MSAL) - Backend Authentication
ENTRA_CLIENT_ID=your_client_id_here
ENTRA_TENANT_ID=your_tenant_id_here
ENTRA_CLIENT_SECRET=your_client_secret_here
# Local: http://localhost:8000/api/auth/callback
# Azure: https://your-app-api.azurecontainerapps.io/api/auth/callback (OBLIGATORIO HTTPS)
ENTRA_REDIRECT_URI=http://localhost:8000/api/auth/callback

# Modo de pruebas para autenticación (true para saltar validación de Microsoft)
MOCK_ENTRA_ID=false

# Session Secret para JWT (debe ser una cadena aleatoria segura de al menos 32 caracteres)
# Genera uno con: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=your_secret_key_here_minimum_32_characters

